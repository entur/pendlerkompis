{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kontrakt A: Data -> Motor",
  "description": "Strukturert data fra Spor 1 til Spor 2",
  "type": "object",
  "required": ["bruker", "avvik", "reisealternativer"],
  "properties": {
    "bruker": {
      "type": "object",
      "required": ["id", "hjem", "jobb", "avreisetider"],
      "properties": {
        "id": { "type": "string" },
        "hjem": {
          "type": "object",
          "required": ["navn", "koordinater"],
          "properties": {
            "navn": { "type": "string" },
            "koordinater": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lon": { "type": "number" }
              }
            }
          }
        },
        "jobb": {
          "type": "object",
          "required": ["navn", "koordinater"],
          "properties": {
            "navn": { "type": "string" },
            "koordinater": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lon": { "type": "number" }
              }
            }
          }
        },
        "avreisetider": {
          "type": "object",
          "properties": {
            "fra_hjem": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
            "fra_jobb": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" }
          }
        },
        "preferanser": {
          "type": "object",
          "properties": {
            "laert": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "situasjon": { "type": "string" },
                  "valgt_handling": { "type": "string" },
                  "antall_ganger": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    },
    "avvik": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kilde", "type", "alvorlighet", "beskrivelse"],
        "properties": {
          "id": { "type": "string" },
          "kilde": { "type": "string", "enum": ["SIRI-SX", "SIRI-ET", "manuell"] },
          "type": { "type": "string" },
          "alvorlighet": { "type": "string", "enum": ["lav", "middels", "hoy"] },
          "beskrivelse": { "type": "string" },
          "paavirker_linjer": { "type": "array", "items": { "type": "string" } },
          "paavirker_stasjoner": { "type": "array", "items": { "type": "string" } },
          "estimert_varighet_min": { "type": "integer" },
          "oppstaat": { "type": "string", "format": "date-time" }
        }
      }
    },
    "reisealternativer": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "beskrivelse", "avgang", "estimert_ankomst", "steg", "status"],
        "properties": {
          "id": { "type": "string" },
          "beskrivelse": { "type": "string" },
          "avgang": { "type": "string", "format": "date-time" },
          "estimert_ankomst": { "type": "string", "format": "date-time" },
          "steg": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "fra", "til", "varighet_min"],
              "properties": {
                "type": { "type": "string", "enum": ["gange", "tog", "buss", "trikk", "tbane", "ferje"] },
                "linje": { "type": "string" },
                "fra": { "type": "string" },
                "til": { "type": "string" },
                "varighet_min": { "type": "integer" }
              }
            }
          },
          "status": { "type": "string", "enum": ["i_rute", "forsinket", "innstilt", "ukjent"] }
        }
      }
    },
    "sanntidsdata": {
      "type": "object",
      "description": "Utvidet sanntidsdata for motoren. Additiv — kan ignoreres av konsumenter som ikke trenger det.",
      "properties": {
        "faktiske_ankomster": {
          "type": "array",
          "description": "Faktiske/estimerte ankomster fra de siste 2 timene for samme linjer og destinasjon.",
          "items": {
            "type": "object",
            "properties": {
              "service_journey_id": { "type": "string" },
              "linje": { "type": "string" },
              "planlagt_ankomst": { "type": "string", "format": "date-time" },
              "faktisk_ankomst": { "type": ["string", "null"], "format": "date-time", "description": "null hvis innstilt" },
              "forsinkelse_min": { "type": ["number", "null"], "description": "Minutter forsinket (negativ = tidlig). null hvis innstilt." },
              "innstilt": { "type": "boolean" }
            }
          }
        },
        "forsinkelsesstatistikk": {
          "type": "array",
          "description": "Empiriske forsinkelser (median og 90-persentil) gruppert per linje og time.",
          "items": {
            "type": "object",
            "properties": {
              "linje": { "type": "string" },
              "stasjon": { "type": "string" },
              "time_paa_doegnet": { "type": "integer", "minimum": 0, "maximum": 23 },
              "median_forsinkelse_min": { "type": "number" },
              "p90_forsinkelse_min": { "type": "number" },
              "antall_observasjoner": { "type": "integer" }
            }
          }
        },
        "innstillinger": {
          "type": "array",
          "description": "Kanselleringer fra reisealternativer og destinasjonens avgangstavle.",
          "items": {
            "type": "object",
            "properties": {
              "service_journey_id": { "type": "string" },
              "linje": { "type": "string" },
              "type": { "type": "string", "enum": ["hel_tur", "delvis"], "description": "hel_tur = hele avgangen innstilt, delvis = enkelt stopp innstilt" },
              "paavirket_stasjon": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}